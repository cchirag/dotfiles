// Dev layout: 3 tabs - Terminal | Editor | AI
layout {
    // Tab 1: Split terminal (left/right)
    tab name="term" {
        pane split_direction="horizontal" {
            pane
            pane
        }
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }

    // Tab 2: Neovim (default focus)
    tab name="nvim" focus=true {
        pane command="nvim" {
            args "."
        }
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }

    // Tab 3: AI (choose claude or opencode)
    tab name="ai" {
        pane command="ai-chooser"
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }
}
