// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // Disable all AI features (Agent panel, inline assist, edit predictions, etc.).
  "disable_ai": true,
  "diff_view_style": "unified",
  // Diff tabs are multibuffers that collapse untouched regions to hunks+context.
  // A huge context count makes them merge into the whole file. NOTE: also widens
  // context in search results / project diff — lower it if that's noisy.
  "excerpt_context_lines": 9999,
  "vim_mode": true,
  "project_panel": {
    "dock": "left",
  },
  // Clicking a file in the git panel opens its diff tab (split style, whole
  // file via excerpt_context_lines above).
  "git_panel": {
    "entry_primary_click_action": "file_diff",
  },
  // Agent panel allowed (cmd-? / space a a); no inline autosuggestions.
  "edit_predictions": {
    "provider": "none",
  },
  "agent": {
    "dock": "bottom",
    "button": false,
  },
  // Claude Code (ACP). Pinning absolute path since macOS GUI apps
  // don't reliably inherit ~/.local/bin in PATH.
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "env": {
        "CLAUDE_CODE_EXECUTABLE": "/Users/chiragchan/.local/bin/claude",
      },
    },
  },

  // Cmd+W on a window with no tabs should NOT close the window/app.
  "when_closing_with_no_tabs": "keep_window_open",

  // Minimal UI chrome
  "tab_bar": { "show": true },
  // Title bar: show branch (name + git status) and project name; hide account/menu chrome.
  "title_bar": {
    "show_branch_name": true,
    "show_branch_status_icon": true,
    "show_project_items": true,
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_user_menu": false,
    "show_sign_in": false,
  },
  "scrollbar": { "show": "never" },
  "minimap": { "show": "always" },
  "indent_guides": { "enabled": false },
  "inlay_hints": { "enabled": false },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
  },
  "status_bar": {
    "active_language_button": true,
    "cursor_position_button": true,
    "line_endings_button": true,
  },
  // Status-bar panel buttons: keep sidebar (project_panel), git, terminal;
  // hide the rest (driven by keybindings instead).
  "terminal": {
    "button": true,
  },
  "outline_panel": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "collaboration_panel": {
    "button": false,
  },

  // From nvim opt.* — see ~/.config/nvim/init.lua
  "relative_line_numbers": "enabled",
  "tab_size": 2,
  "hard_tabs": false,
  "soft_wrap": "none",
  "vertical_scroll_margin": 8,
  "cursor_blink": false,
  "format_on_save": "on",
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
  },

  // Per-server settings — mirrors ~/.config/nvim/init.lua.
  // JS/TS (vtsls), Rust, Go, Python, Lua servers are otherwise fine on defaults.
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "procMacro": { "enable": false },
        "cargo": { "allFeatures": false },
        "checkOnSave": true,
        "check": { "command": "check" },
        "lens": { "enable": false },
        "inlayHints": { "enable": false },
      },
    },
    "lua-language-server": {
      "settings": {
        "Lua": {
          "diagnostics": { "globals": ["vim"] },
          "workspace": { "checkThirdParty": false },
          "telemetry": { "enable": false },
        },
      },
    },
  },

  // Rust/TS/JS/Go/Python/TOML ship built-in; only Lua needs an extension.
  "auto_install_extensions": {
    "lua": true,
  },

  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "ui_font_size": 13,
  "buffer_font_size": 12,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Zedokai (Filter Spectrum)",
  },
}
